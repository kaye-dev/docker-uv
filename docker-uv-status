#!/bin/sh
set -eu

resolve_path() {
  target=$1

  while [ -L "$target" ]; do
    target_dir=$(CDPATH='' cd -- "$(dirname -- "$target")" && pwd -P)
    target_link=$(readlink "$target")

    case "$target_link" in
      /*) target=$target_link ;;
      *) target=$target_dir/$target_link ;;
    esac
  done

  target_dir=$(CDPATH='' cd -- "$(dirname -- "$target")" && pwd -P)
  printf '%s/%s\n' "$target_dir" "$(basename -- "$target")"
}

SCRIPT_PATH=$(resolve_path "$0")
REPO_ROOT=$(CDPATH='' cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd -P)
. "$REPO_ROOT/docker-uv-common.sh"

docker_uv_init "$SCRIPT_PATH"
docker_uv_print_review_candidates "${DOCKER_UV_RECOMMEND_AFTER_DAYS:-30}"
